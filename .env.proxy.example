# Proxy environment variables

# Required
STACKS_NETWORK=testnet
SELLER_PRIVATE_KEY=<hex-encoded-private-key>
SERVICE_PRINCIPAL=<derived-stacks-principal>

# Required Clarity contract references (format: <address>.<contract-name>)
SERVICE_REGISTRY_ADDRESS=
REPUTATION_MAP_ADDRESS=
DISPUTE_RESOLVER_ADDRESS=
RECEIPT_ANCHOR_ADDRESS=

# Optional overrides
# STACKS_API_URL=https://api.testnet.hiro.so
# CONFIRMATION_DEPTH_MAINNET=6
# CONFIRMATION_DEPTH_TESTNET=1
# REPLAY_WINDOW_SECONDS=300
# TIMESTAMP_BUCKET_SECONDS=300

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stxact

# Feature flags
ENABLE_RECEIPT_ANCHORING=false
ENABLE_DEMO_ROUTES=false
MIN_REPUTATION_AMOUNT=10000
