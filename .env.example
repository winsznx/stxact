# stxact Environment Configuration
# Copy this file to .env and fill in the values

# =============================================================================
# SERVER CONFIGURATION
# =============================================================================
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# =============================================================================
# DATABASE CONFIGURATION
# =============================================================================
DATABASE_URL=postgresql://stxact:password@localhost:5432/stxact
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_USER=stxact
POSTGRES_PASSWORD=changeme
POSTGRES_DB=stxact

# =============================================================================
# REDIS CONFIGURATION
# =============================================================================
REDIS_URL=redis://localhost:6379

# =============================================================================
# STACKS BLOCKCHAIN CONFIGURATION
# =============================================================================
# Network: testnet or mainnet
STACKS_NETWORK=testnet

# Stacks API URL
STACKS_API_URL=https://api.testnet.hiro.so

# Seller Private Key (NEVER commit actual keys)
# This is the key used to sign receipts
SELLER_PRIVATE_KEY=your_private_key_here

# Service Principal (derived from SELLER_PRIVATE_KEY)
SERVICE_PRINCIPAL=ST2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7

# Service BNS Name (optional)
SERVICE_BNS_NAME=

# =============================================================================
# CLARITY CONTRACT ADDRESSES (deployed on Stacks)
# =============================================================================
SERVICE_REGISTRY_ADDRESS=ST2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7.service-registry
REPUTATION_MAP_ADDRESS=ST2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7.reputation-map
DISPUTE_RESOLVER_ADDRESS=ST2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7.dispute-resolver
RECEIPT_ANCHOR_ADDRESS=ST2J6ZY48GV1EZ5V2V5RB9MP66SW86PYKKNRV9EJ7.receipt-anchor

# =============================================================================
# X402 FACILITATOR CONFIGURATION
# =============================================================================
# Official x402-stacks facilitator (production-ready)
X402_FACILITATOR_URL=https://facilitator.stacksx402.com

# =============================================================================
# SECURITY CONFIGURATION
# =============================================================================
# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:3000,http://localhost:3001

# Rate limiting (requests per minute)
RATE_LIMIT_MAX=100

# Session secret for signed cookies
SESSION_SECRET=changeme_random_string_here

# =============================================================================
# FEATURE FLAGS
# =============================================================================
# Enable optional receipt anchoring to on-chain contract
ENABLE_RECEIPT_ANCHORING=false

# Enable demo-only routes like /demo/premium-data
# Set true for public testnet verification if NODE_ENV=production and you need the paid test endpoints live
ENABLE_DEMO_ROUTES=false

# Minimum reputation amount for crediting (sats)
# Default: 10000 sats (PRD Section 12)
MIN_REPUTATION_AMOUNT=10000

# =============================================================================
# BLOCKCHAIN CONFIRMATION DEPTH
# =============================================================================
# Number of confirmations required before payment is considered final
# Testnet: 1 block (default)
# Mainnet: 6 blocks (default)
CONFIRMATION_DEPTH_TESTNET=1
CONFIRMATION_DEPTH_MAINNET=6

# =============================================================================
# TIMESTAMP BUCKET CONFIGURATION
# =============================================================================
# Timestamp bucket size in seconds (default: 300 = 5 minutes)
TIMESTAMP_BUCKET_SIZE=300

# =============================================================================
# DISPUTE CONFIGURATION
# =============================================================================
# Dispute window in seconds (default: 86400 = 24 hours)
DISPUTE_WINDOW_SECONDS=86400

# Resolution window in blocks (default: 1008 = ~7 days)
RESOLUTION_WINDOW_BLOCKS=1008

# =============================================================================
# CACHE TTL CONFIGURATION
# =============================================================================
# BNS lookup cache TTL in seconds (default: 3600 = 1 hour)
BNS_CACHE_TTL=3600

# Directory listing cache TTL in seconds (default: 300 = 5 minutes)
DIRECTORY_CACHE_TTL=300

# Payment verification cache TTL in seconds (default: 600 = 10 minutes)
PAYMENT_VERIFICATION_CACHE_TTL=600

# Idempotency cache TTL in seconds (default: 600 = 10 minutes)
IDEMPOTENCY_CACHE_TTL=600

# =============================================================================
# MONITORING & OBSERVABILITY
# =============================================================================
# Datadog API key (optional)
DATADOG_API_KEY=

# Sentry DSN (optional)
SENTRY_DSN=

# =============================================================================
# BACKUP CONFIGURATION
# =============================================================================
# S3 bucket for database backups
S3_BACKUP_BUCKET=

# AWS credentials for S3 backups
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_REGION=us-east-1

# =============================================================================
# SERVICE POLICY CONFIGURATION
# =============================================================================
# Service policy JSON URL (publicly accessible)
SERVICE_POLICY_URL=https://api.example.com/policy.json

# Service policy hash (SHA-256 of policy JSON)
SERVICE_POLICY_HASH=

# =============================================================================
# UPSTREAM SERVICE CONFIGURATION
# =============================================================================
# Upstream API base URL (the actual service behind stxact proxy)
UPSTREAM_SERVICE_URL=http://localhost:4000

# Timeout for sync endpoints (seconds)
SYNC_ENDPOINT_TIMEOUT=30

# Timeout for async jobs (seconds)
ASYNC_JOB_TIMEOUT=3600
