# Root environment - shared between webapp and proxy

# REQUIRED: choose mainnet or testnet (no default in production)
STACKS_NETWORK=testnet
NEXT_PUBLIC_STACKS_NETWORK=testnet

# Optional API URL overrides (default derives from network)
# STACKS_API_URL=https://api.testnet.hiro.so
# NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

# Confirmation depth (mainnet defaults to 6, testnet to 1)
# CONFIRMATION_DEPTH_MAINNET=6
# CONFIRMATION_DEPTH_TESTNET=1

# Replay protection
# REPLAY_WINDOW_SECONDS=300
# TIMESTAMP_BUCKET_SECONDS=300

# stxact contract references (deployer.contract-name)
SERVICE_REGISTRY_ADDRESS=
REPUTATION_MAP_ADDRESS=
DISPUTE_RESOLVER_ADDRESS=
RECEIPT_ANCHOR_ADDRESS=

# Seller credentials
SELLER_PRIVATE_KEY=
SERVICE_PRINCIPAL=

# Server
PORT=3001
NODE_ENV=development
LOG_LEVEL=info

# Database
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=stxact

# Webapp
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001
NEXT_PUBLIC_APP_NAME=stxact
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_ENABLE_DISPUTES=true
NEXT_PUBLIC_ENABLE_RECEIPT_ANCHORING=false
NEXT_PUBLIC_ENABLE_REPUTATION=true
