# Webapp environment variables
NEXT_PUBLIC_API_URL=http://127.0.0.1:3001

# Required: explicitly choose mainnet or testnet (no default)
NEXT_PUBLIC_STACKS_NETWORK=testnet

# Optional override (auto-derived from network if unset)
# NEXT_PUBLIC_STACKS_API_URL=https://api.testnet.hiro.so

NEXT_PUBLIC_APP_NAME=stxact
NEXT_PUBLIC_APP_URL=http://localhost:3000

NEXT_PUBLIC_ENABLE_DISPUTES=true
NEXT_PUBLIC_ENABLE_RECEIPT_ANCHORING=false
NEXT_PUBLIC_ENABLE_REPUTATION=true
